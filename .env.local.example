VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Comma-separated list of emails allowed to sign in.
# If empty, ANY email can request a magic link (DEV ONLY — never in production).
VITE_ALLOWED_EMAILS=you@example.com

# NOT prefixed with VITE_ — keeps the key out of the client bundle.
# Currently unused in the SPA; needed if AI generation is added via a serverless function.
AI_API_KEY=your-api-key
