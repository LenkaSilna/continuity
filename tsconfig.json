{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": [
    "src",
    "lib",
    "app/_components",
    "app/ai/_components",
    "app/ai/custom/_components",
    "app/calendar/_components",
    "app/calendar/[date]/_components",
    "app/library/habits/_components",
    "app/library/observations/_components",
    "app/library/products/_components",
    "app/library/supplements/_components",
    "app/routine/_components",
    "app/settings/_components",
    "app/profile/_components",
    "vite.config.ts"
  ]
}
